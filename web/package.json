{
  "name": "jiotv-go-web",
  "description": "Frontend for JioTV Go - Web interface and styling",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "daisyui": "^5.5.19",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.4"
  },
  "scripts": {
    "build": "tailwindcss -i ./static/internal/input.css -o ./static/internal/tailwind.css --minify",
    "watch": "tailwindcss -i ./static/internal/input.css -o ./static/internal/tailwind.css --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  }
}
